windows.debug.x86_64 = "res://addons/Godot-Unified-Particle-System/bin/libunified_particle_system.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/Godot-Unified-Particle-System/bin/libunified_particle_system.windows.template_release.x86_64.dll"
macos.debug = "res://addons/Godot-Unified-Particle-System/bin/libunified_particle_system.macos.template_debug.framework"
